# Expo + React Native expect a flat node_modules. The hoisted linker avoids
# pnpm's isolated-store symlink layout, which breaks Metro resolution and
# native autolinking (CocoaPods / Gradle). See CLAUDE.md §4 mapping.
node-linker=hoisted

# Hoist Expo / React Native / Metro packages to the workspace-root node_modules.
# pnpm hoists transitive tooling (e.g. @expo/metro-config) to the root, where it
# does `require.resolve('expo/package.json')`; without this, `expo` + react-native
# stay stranded in apps/mobile/node_modules and `expo start` dies with
# "Cannot find module 'expo/package.json'".
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=metro*

# The mobile app installs every real native dependency itself (via `expo
# install`), so peers are satisfied by the app's hoisted copies. Disabling
# auto-install keeps pnpm from speculatively pulling mismatched react /
# react-native versions during intermediate install states.
auto-install-peers=false
strict-peer-dependencies=false
